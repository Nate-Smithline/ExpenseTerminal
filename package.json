    "@supabase/supabase-js": "^2.49.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "emoji-picker-react": "^4.18.0",
    "exceljs": "^4.4.0",
    "jspdf": "^4.1.0",
